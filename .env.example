# Скопіюйте цей файл у .env і заповніть значення
# cp .env.example .env

# ── Flask ─────────────────────────────────────────────────────────────────────
# Секретний ключ сесій (згенеруйте: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Формат: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Приклад локально:  postgresql://postgres:password@localhost:5432/appser
# Приклад VPS:       postgresql://appser_user:StrongPass@192.168.1.10:5432/appser_db
DATABASE_URL=postgresql://user:password@localhost:5432/appser

# ── Celery / Redis ────────────────────────────────────────────────────────────
# Потрібен для асинхронної генерації PDF
# Приклад: redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Авторизація ───────────────────────────────────────────────────────────────
# ВАЖЛИВО: обов'язково змініть ці значення на надійні перед розгортанням!
APP_LOGIN=admin
APP_PASSWORD=change_me_please
